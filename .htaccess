# Protect non-public directories from direct web access
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to app/, cron/, logs/, sql/, templates/ directories
    RewriteRule ^app/ - [F,L]
    RewriteRule ^cron/ - [F,L]
    RewriteRule ^logs/ - [F,L]
    RewriteRule ^sql/ - [F,L]
    RewriteRule ^templates/ - [F,L]

    # Block access to dotfiles
    RewriteRule (^\.|/\.) - [F,L]
</IfModule>

# Deny access to sensitive files
<FilesMatch "\.(env|sql|log|md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
